// Theme Toggle Event Listener
document.getElementById('theme-checkbox').addEventListener('change', function(e) {
  if (e.target.checked) {
    document.body.classList.add('fiori-theme');
    setStatus('✔ Fiori Launchpad theme activated');
  } else {
    document.body.classList.remove('fiori-theme');
    setStatus('✔ Classic SAP GUI theme activated');
  }
});

// Clock
function tick() {
  document.getElementById('status-clock').textContent =
    new Date().toTimeString().slice(0,8) + ' IST';
}
tick(); setInterval(tick, 1000);

// Group box expand/collapse
function toggleGroup(titleEl) {
  const box = titleEl.closest('.group-box');
  box.classList.toggle('collapsed');
}

// Navigation for both Tabs and Tree Links
function navToSection(id, element) {
  // Scroll
  const target = document.getElementById(id);
  if(target) target.scrollIntoView({behavior:'smooth', block:'start'});
  
  // Highlight Tab or Tree Item appropriately
  if (element.classList.contains('tree-item')) {
    document.querySelectorAll('.tree-item').forEach(t => t.classList.remove('active'));
    element.classList.add('active');
  }
  
  if (element.classList.contains('tab')) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    element.classList.add('active');
    setStatus('✔ Tab selected: ' + element.textContent.trim());
  }
}

// Experience row detail toggle
function showExp(id, rowElement) {
  const allRows = rowElement.closest('tbody').querySelectorAll('tr');
  allRows.forEach(r => {
    r.querySelector('td:first-child').textContent = '○';
    r.classList.remove('selected');
  });
  rowElement.querySelector('td:first-child').textContent = '◉';
  rowElement.classList.add('selected');
  
  document.getElementById('exp1').style.display = (id === 'exp1') ? 'block' : 'none';
  document.getElementById('exp2').style.display = (id === 'exp2') ? 'block' : 'none';
  
  setStatus(id === 'exp1'
    ? '✔ Record: EY GDS / Nvidia Corporation – Jun 2024 to Present'
    : '✔ Record: Accenture / KSB Pumps & Valves – Oct 2021 to Jun 2024'
  );
}

// Status bar
function setStatus(msg) {
  document.getElementById('status-msg').textContent = msg;
}

// Scroll reveal for group boxes
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
  });
}, { threshold: 0.05, root: document.getElementById('form-body') });
document.querySelectorAll('.group-box').forEach(b => io.observe(b));

// Counter animation
function animCount(el, target) {
  let s = null; const dur = 1200;
  const step = ts => {
    if (!s) s = ts;
    const p = Math.min((ts-s)/dur, 1);
    const ease = p < .5 ? 2*p*p : -1+(4-2*p)*p;
    el.textContent = Math.floor(ease * target) + '+';
    if (p < 1) requestAnimationFrame(step);
    else el.textContent = target + '+';
  };
  requestAnimationFrame(step);
}
// trigger on load
setTimeout(() => {
  document.querySelectorAll('[data-target]').forEach(el => animCount(el, +el.dataset.target));
}, 400);

// Hover status messages
document.querySelectorAll('.tb-btn').forEach(btn => {
  btn.addEventListener('mouseenter', () => setStatus('ℹ ' + (btn.title || 'Toolbar button')));
  btn.addEventListener('mouseleave', () => setStatus('✔ Record HKS_PP_QM read successfully (T-Code: ZHR_PROFILE)'));
});

document.querySelectorAll('.menu-item').forEach(m => {
